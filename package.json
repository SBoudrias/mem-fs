{
  "name": "@mem-fs/root",
  "private": true,
  "license": "MIT",
  "author": "Simon Boudrias <admin@simonboudrias.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/SBoudrias/mem-fs.git"
  },
  "workspaces": [
    "packages/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "prepare": "git config --local include.path ../.gitconfig || true",
    "prepublishOnly": "yarn tsc",
    "pretest": "package lint --check && eslint . && oxfmt --check && yarn tsc",
    "test": "vitest run --coverage",
    "tsc": "turbo tsc && tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@lerna-lite/cli": "^5.0.0",
    "@lerna-lite/publish": "^5.0.0",
    "@repo/tsconfig": "workspace:*",
    "@sboudrias/package": "^1.0.1",
    "@types/node": ">=18",
    "@types/vinyl": "^2.0.12",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-xo": "^0.50.0",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.52.0",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.0.18"
  },
  "nano-staged": {
    "*": "yarn oxfmt --no-error-on-unmatched-pattern",
    "*.m?[jt]sx?": "yarn eslint --fix"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "yarn@4.15.0+sha512.07ec708ac11e2eaa4ea2b04cfbb272812f7e74a753f1595eaef4486c663a98306a30cca3e6fc40f7a0b168dcfb3a2490b6a5e0501e20fb69cc36f563dd161c53"
}
